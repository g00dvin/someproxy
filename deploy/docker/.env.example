# Call-VPN Server Configuration
# Copy this file to .env and adjust values as needed.

# Docker image tag (default: main)
# Use "main" for latest build from main branch, or specific version like "1.0.0"
IMAGE_TAG=main

# UDP port exposed on host (default: 9000)
LISTEN_PORT=9000

# Auth token for client connections (optional, empty = no auth)
VPN_TOKEN=

# Slack webhook URL for monitoring alerts (optional)
SIREN_SLACK_WEBHOOK=

# Resource limits
MEMORY_LIMIT=256M
CPU_LIMIT=1.0
